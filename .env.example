# =====================================================================
# RizzTalk — Environment Variables Template
# Copy this file to .env and fill in your actual values.
# NEVER commit .env with real secrets to git.
# =====================================================================

# --- Supabase (Frontend — safe to expose, anon key only) ---
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# --- Supabase project ref (optional, for CLI usage) ---
VITE_SUPABASE_PROJECT_ID=YOUR_PROJECT_REF

# =====================================================================
# Edge Function secrets — set these in Supabase Dashboard:
# Project Settings > Edge Functions > Secrets
# DO NOT put these in .env (they are server-side only)
# =====================================================================
# LOVABLE_API_KEY=<your Lovable API key>
# TELEGRAM_API_KEY=<your Telegram Bot token from @BotFather>
# TELEGRAM_WEBHOOK_SECRET=<random secret for webhook verification>
# SUPABASE_SERVICE_ROLE_KEY=<service role key — NEVER expose to frontend>
# QRIS_IMAGE_URL=https://<project>.supabase.co/storage/v1/object/public/assets/qris.jpg
# PAYMENT_MERCHANT=Secret Shop
# PAYMENT_NMID=ID1026507854309
